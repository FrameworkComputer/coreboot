	default 36

config POST_DEVICE
	default n

config UART_FOR_CONSOLE
	default 0

# PM Timer Disabled, saves power
config USE_PM_ACPI_TIMER
	default n

# The two USB-C PD controllers are programmed from firmware stored at fixed
# offsets near the start of the BIOS region (the PD1/PD2 FMAP regions in
# board.fmd). Point these at the PD firmware blobs to embed them at build time.
# An option left empty builds its region empty (0xff), so flashing preserves
# whatever PD firmware is already present on the chip.
config FRAMEWORK_PD1_FW_FILE
	string "PD1 firmware blob"
	default ""
	help
	  Path to the PD1 controller firmware. Must fit the PD1 FMAP region
	  (64K). Leave empty to not touch the PD1 region.

config FRAMEWORK_PD2_FW_FILE
	string "PD2 firmware blob"
	default ""
	help
	  Path to the PD2 controller firmware. Must fit the PD2 FMAP region
	  (64K). Leave empty to not touch the PD2 region.

# The Embedded Controller firmware lives in its own Intel flash descriptor
# region (SI_EC, see board.fmd), outside the BIOS region coreboot normally
# flashes. Setting this embeds the blob into SI_EC of the built image; left
# empty the region stays empty (0xff). Note: flashing it requires writing the
# EC region explicitly (e.g. flashrom with a layout), since coreboot's image
# carries no Intel Firmware Descriptor.
config FRAMEWORK_EC_FW_FILE
	string "EC firmware blob"
	default ""
	help
	  Path to the Embedded Controller firmware. Must fit the SI_EC FMAP
	  region (512K). Leave empty to not touch the EC region.

endif
